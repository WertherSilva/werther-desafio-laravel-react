### Variables
@baseUrl = http://localhost:8000
@jwtToken = {{loginRequest.response.body.*}}

### Login
# @name loginRequest
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
    "email": "analista@seplag.rj.gov.br",
    "password": "orcamento@2026"
}

### GET /orcamentos
GET {{baseUrl}}/api/orcamentos
    ?orgao_id=
    &programa_id=
    &acao_id=
    &ano=
    &status=
    &percentual_minimo=
    &percentual_maximo=
    &per_page=100
    &page=1
    &sort_by=
    &sort_direction=
Authorization: Bearer {{jwtToken}}
Accept: application/json

### GET /orcamentos/:id
GET {{baseUrl}}/api/orcamentos/174
Authorization: Bearer {{jwtToken}}
Accept: application/json

### PATCH /orcamentos/:id/revisao
PATCH {{baseUrl}}/api/orcamentos/16/revisao
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

{
    "observacao_revisao": "Testanto observação de revisão. Esse pode ser um texto longo."
}